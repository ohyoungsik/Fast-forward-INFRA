[SERVICE]
    Flush        3
    Daemon       Off
    Log_Level    info
    Parsers_File /etc/fluent-bit/parsers.conf

# =========================
# Nginx access.log 수집
# =========================
[INPUT]
    Name              tail
    Path              /var/log/nginx/access.log
    Tag               nginx.access
    Parser            nginx
    DB                /var/lib/fluent-bit/nginx_access.db
    Read_from_Head    true

# =========================
# Nginx error.log 수집
# =========================
[INPUT]
    Name              tail
    Path              /var/log/nginx/error.log
    Tag               nginx.error
    DB                /var/lib/fluent-bit/nginx_error.db
    Read_from_Head    true

# =========================
# Linux auth.log 수집
# SSH / sudo / session 로그
# =========================
[INPUT]
    Name              tail
    Path              /var/log/auth.log
    Tag               auth.log
    DB                /var/lib/fluent-bit/auth_log.db
    Read_from_Head    true

# =========================
# nginx access.log 메타데이터 추가
# =========================
[FILTER]
    Name   modify
    Match  nginx.access
    Add    log_type nginx_access
    Add    source_path /var/log/nginx/access.log
    Add    server_name {{ ansible_hostname }}
    Add    server_role {{ server_role | default('unknown') }}

# =========================
# nginx error.log 메타데이터 추가
# =========================
[FILTER]
    Name   modify
    Match  nginx.error
    Add    log_type nginx_error
    Add    source_path /var/log/nginx/error.log
    Add    server_name {{ ansible_hostname }}
    Add    server_role {{ server_role | default('unknown') }}

# =========================
# auth.log 메타데이터 추가
# =========================
[FILTER]
    Name   modify
    Match  auth.log
    Add    log_type auth_log
    Add    source_path /var/log/auth.log
    Add    server_name {{ ansible_hostname }}
    Add    server_role {{ server_role | default('unknown') }}

# =========================
# FastAPI /api/v1/security/logs/ingest 엔드포인트로 전송
# =========================
[OUTPUT]
    Name     http
    Match    auth.log
    Host     {{ fluentbit_output_host }}
    Port     {{ fluentbit_output_port }}
    URI      /api/v1/security/logs/ingest
    Format   json
    Header   Content-Type application/json

# =========================
# FastAPI /api/v1/logs/ingest  엔드포인트로 전송  (nginx log)
# =========================
[OUTPUT]
    Name   http
    Match  nginx.*
    Host     {{ fluentbit_output_host }}
    Port     {{ fluentbit_output_port }}
    URI    /api/v1/logs/ingest
    Format json
    Header   Content-Type application/json